---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  author: string;
  tags: string[];
  category: string;
  slug: string;
}

const { title, description, pubDate, updatedDate, heroImage, author, tags, category, slug } = Astro.props;
const postCanonical = `https://streamvault.tv/blog/${slug}/`;

const formattedDate = pubDate.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
const formattedUpdate = updatedDate?.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });

const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(p => p.data.title !== title)
  .filter(p => p.data.tags?.some((t: string) => tags.includes(t)) || p.data.category === category)
  .slice(0, 3);

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "author": { "@type": "Person", "name": author },
  "publisher": { "@type": "Organization", "name": "StreamVault", "url": "https://streamvault.tv" },
  "datePublished": pubDate.toISOString(),
  ...(updatedDate ? { "dateModified": updatedDate.toISOString() } : {}),
  ...(heroImage ? { "image": heroImage } : {}),
  "mainEntityOfPage": { "@type": "WebPage" },
  "inLanguage": "en-GB"
};
---
<Layout title={`${title} | StreamVault Blog`} description={description} schema={articleSchema} canonical={postCanonical} ogType="article">
  <Header />
  <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Blog', href: '/blog' }, { label: title }]} />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 pb-24">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-12">
      <main>
        {heroImage && (
          <div class="rounded-2xl overflow-hidden mb-8 aspect-video bg-dark-800">
            <img src={heroImage} alt={title} class="w-full h-full object-cover" loading="lazy" />
          </div>
        )}

        <div class="mb-8">
          <div class="flex flex-wrap items-center gap-3 mb-4">
            <span class="px-3 py-1 rounded-full bg-brand-500/10 border border-brand-500/20 text-brand-400 text-xs font-medium uppercase tracking-wider">{category}</span>
            {tags.map((tag) => (
              <span class="px-2.5 py-0.5 rounded-full bg-white/5 text-slate-400 text-xs">{tag}</span>
            ))}
          </div>
          <h1 class="text-3xl md:text-4xl font-bold text-white mb-4 leading-tight">{title}</h1>
          <div class="flex items-center gap-4 text-sm text-slate-400">
            <span>By <strong class="text-slate-300">{author}</strong></span>
            <span class="w-1 h-1 rounded-full bg-slate-600" aria-hidden="true"></span>
            <time datetime={pubDate.toISOString()}>{formattedDate}</time>
            {formattedUpdate && (
              <>
                <span class="w-1 h-1 rounded-full bg-slate-600" aria-hidden="true"></span>
                <span>Updated: {formattedUpdate}</span>
              </>
            )}
          </div>
        </div>

        <article class="prose prose-invert prose-lg max-w-none prose-headings:text-white prose-headings:font-bold prose-p:text-slate-300 prose-p:leading-relaxed prose-a:text-brand-400 prose-a:no-underline hover:prose-a:underline prose-strong:text-white prose-li:text-slate-300 prose-img:rounded-xl prose-hr:border-white/10">
          <slot />
        </article>
      </main>

      <aside class="space-y-8">
        <div class="rounded-2xl bg-gradient-to-b from-brand-500/15 to-dark-800/60 border border-brand-500/20 p-6 text-center sticky top-24">
          <h3 class="text-lg font-bold text-white mb-2">Start Streaming Today</h3>
          <p class="text-sm text-slate-400 mb-5">Access 20,000+ channels in stunning 4K quality.</p>
          <a href="/#pricing" class="block w-full py-3 rounded-xl bg-brand-500 hover:bg-brand-400 text-white font-semibold text-sm transition-all shadow-lg shadow-brand-500/30 hover:shadow-brand-400/40 text-center">
            Join StreamVault Now
          </a>
        </div>

        {relatedPosts.length > 0 && (
          <div class="rounded-2xl bg-dark-800/40 border border-white/[0.06] p-6">
            <h3 class="text-base font-bold text-white mb-4">Related Posts</h3>
            <ul class="space-y-4" role="list">
              {relatedPosts.map((post) => (
                <li>
                  <a href={`/blog/${post.id.replace(/\.md$/, '')}/`} class="group block">
                    <p class="text-sm font-medium text-slate-300 group-hover:text-brand-400 transition-colors leading-snug mb-1">{post.data.title}</p>
                    <p class="text-xs text-slate-500">{post.data.pubDate.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' })}</p>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </aside>
    </div>
  </div>
  <Footer />
</Layout>
