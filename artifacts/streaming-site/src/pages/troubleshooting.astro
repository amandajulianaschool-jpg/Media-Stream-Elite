---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getWhatsAppSupportLink } from '../i18n/whatsapp';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FaqAccordion from '../components/react/TroubleshootingAccordion';

const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Troubleshooting Guide",
  "description": "Common troubleshooting solutions for StreamVault — fix buffering, login errors, DNS issues, and more.",
  "publisher": { "@type": "Organization", "name": "StreamVault" }
};
---
<Layout
  title="Troubleshooting | StreamVault"
  description="Common troubleshooting solutions for StreamVault — fix buffering, login errors, DNS setup, playback issues, and more."
  schema={pageSchema}
  canonical="https://www.streamvault.com/troubleshooting"
>
  <Header />
  <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Troubleshooting' }]} />

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 pb-24">
    <div class="text-center mb-16">
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-4">Troubleshooting Guide</h1>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto">Quick solutions to common issues. If you can't find your answer here, our 24/7 support team is always ready to help.</p>
    </div>

    <FaqAccordion client:load />

    <div class="mt-16 text-center rounded-2xl bg-gradient-to-r from-brand-500/10 to-brand-600/5 border border-brand-500/20 p-8 md:p-12">
      <h2 class="text-2xl font-bold text-white mb-3">Still Having Issues?</h2>
      <p class="text-slate-400 mb-6 max-w-lg mx-auto">Our expert support team is available 24/7 to help resolve any problem. We typically respond within 2 minutes.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href={getWhatsAppSupportLink('en')} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 bg-[#25d366] hover:bg-[#22c55e] text-white font-semibold rounded-xl transition-all shadow-lg shadow-green-500/25">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp Support
        </a>
        <a href="mailto:support@streamvault.tv" class="inline-flex items-center gap-2 px-6 py-3 border border-white/10 text-slate-300 hover:text-white hover:bg-white/5 rounded-xl transition-all font-medium">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          Email Support
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
