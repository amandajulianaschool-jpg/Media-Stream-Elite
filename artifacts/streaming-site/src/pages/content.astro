---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import ContentShowcase from '../components/ContentShowcase.astro';
import Footer from '../components/Footer.astro';
import { contentPageMeta, getLocaleUrl } from '../i18n/translations';

const locale = 'en' as const;
const meta = contentPageMeta[locale];
---
<Layout locale={locale} title={meta.title} description={meta.description} canonical={`${getLocaleUrl(locale)}content/`}>
  <Header locale={locale} />
  <main class="pt-24">
    <ContentShowcase locale={locale} />
  </main>
  <Footer locale={locale} />
</Layout>
