---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const pageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "StreamVault Blog",
  "description": "Streaming tips, device guides, content recommendations, and service updates from the StreamVault team.",
  "publisher": { "@type": "Organization", "name": "StreamVault", "url": "https://streamvault.tv" }
};

const categoryColors: Record<string, string> = {
  news: 'from-blue-500 to-indigo-700',
  tutorials: 'from-emerald-500 to-teal-700',
  reviews: 'from-purple-500 to-violet-700',
  tips: 'from-amber-500 to-orange-700',
};
---
<Layout
  title="Blog | StreamVault – Streaming Tips, Guides & News"
  description="Streaming tips, device guides, content recommendations, and service updates from the StreamVault team."
  schema={pageSchema}
  canonical="https://streamvault.tv/blog"
>
  <Header />
  <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Blog' }]} />

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 pb-24">
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1 rounded-full bg-brand-500/10 border border-brand-500/20 text-brand-400 text-sm font-medium mb-4">StreamVault Blog</span>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-4">
        Tips, Guides &amp; <span class="text-brand-400">Streaming News</span>
      </h1>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto">Stay updated with the latest streaming tips, device guides, and entertainment news.</p>
    </div>

    {allPosts.length === 0 ? (
      <div class="text-center py-20">
        <p class="text-slate-400 text-lg">No blog posts yet. Check back soon!</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {allPosts.map((post) => (
          <article class="group rounded-2xl bg-dark-800/40 border border-white/[0.06] overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:border-brand-500/20 hover:shadow-xl hover:shadow-brand-500/5">
            <a href={`/blog/${post.id.replace(/\.md$/, '')}/`} class="block">
              <div class={`aspect-video bg-gradient-to-br ${categoryColors[post.data.category] || 'from-brand-500 to-brand-700'} relative overflow-hidden`}>
                {post.data.heroImage ? (
                  <img src={post.data.heroImage} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-white/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg>
                  </div>
                )}
                <div class="absolute top-3 left-3">
                  <span class="px-2.5 py-1 rounded-full bg-black/40 backdrop-blur-sm text-white text-[10px] font-bold uppercase tracking-wider">{post.data.category}</span>
                </div>
              </div>

              <div class="p-6">
                <div class="flex flex-wrap gap-2 mb-3">
                  {post.data.tags.slice(0, 3).map((tag: string) => (
                    <span class="px-2 py-0.5 rounded-full bg-white/5 text-slate-500 text-[11px]">{tag}</span>
                  ))}
                </div>

                <h2 class="text-lg font-bold text-white mb-2 group-hover:text-brand-400 transition-colors leading-snug line-clamp-2">{post.data.title}</h2>

                <p class="text-sm text-slate-400 leading-relaxed mb-4 line-clamp-2">{post.data.description}</p>

                <div class="flex items-center justify-between">
                  <time datetime={post.data.pubDate.toISOString()} class="text-xs text-slate-500">
                    {post.data.pubDate.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' })}
                  </time>
                  <span class="text-sm text-brand-400 font-medium group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">
                    Read More
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
                  </span>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    )}
  </main>
  <Footer />
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
