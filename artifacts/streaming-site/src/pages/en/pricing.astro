---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Pricing from '../../components/Pricing.astro';
import FreeTrial from '../../components/FreeTrial.astro';
import Footer from '../../components/Footer.astro';
import { pricingPageMeta, getLocaleUrl } from '../../i18n/translations';

export const prerender = true;

const locale = 'en' as const;
const meta = pricingPageMeta[locale];
---
<Layout locale={locale} title={meta.title} description={meta.description} canonical={`${getLocaleUrl(locale)}pricing/`}>
  <Header locale={locale} />
  <main class="pt-24">
    <Pricing locale={locale} headingLevel="h1" />
    <FreeTrial locale={locale} />
  </main>
  <Footer locale={locale} />
</Layout>
