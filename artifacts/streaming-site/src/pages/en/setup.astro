---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Setup from '../../components/Setup.astro';
import Footer from '../../components/Footer.astro';
import { setupPageMeta, getLocaleUrl } from '../../i18n/translations';

export const prerender = true;

const locale = 'en' as const;
const meta = setupPageMeta[locale];
---
<Layout locale={locale} title={meta.title} description={meta.description} canonical={`${getLocaleUrl(locale)}setup/`}>
  <Header locale={locale} />
  <main class="pt-24">
    <Setup locale={locale} headingLevel="h1" />
  </main>
  <Footer locale={locale} />
</Layout>
