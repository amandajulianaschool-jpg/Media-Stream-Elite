---
import type { Locale } from '../i18n/translations';
import { t } from '../i18n/ui';
import CookieBanner from './react/CookieBanner';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const privacyHref = '/privacy';
---
<CookieBanner
  client:load
  message={t(locale, 'cookie.message')}
  acceptAll={t(locale, 'cookie.acceptAll')}
  rejectAll={t(locale, 'cookie.rejectAll')}
  settings={t(locale, 'cookie.settings')}
  settingsTitle={t(locale, 'cookie.settingsTitle')}
  necessary={t(locale, 'cookie.necessary')}
  necessaryDesc={t(locale, 'cookie.necessaryDesc')}
  analytics={t(locale, 'cookie.analytics')}
  analyticsDesc={t(locale, 'cookie.analyticsDesc')}
  functional={t(locale, 'cookie.functional')}
  functionalDesc={t(locale, 'cookie.functionalDesc')}
  marketing={t(locale, 'cookie.marketing')}
  marketingDesc={t(locale, 'cookie.marketingDesc')}
  savePreferences={t(locale, 'cookie.savePreferences')}
  privacyLink={t(locale, 'cookie.privacyLink')}
  privacyHref={privacyHref}
/>
