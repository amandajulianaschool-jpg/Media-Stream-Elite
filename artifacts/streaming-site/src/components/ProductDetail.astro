---
import { Image } from 'astro:assets';
import type { Locale } from '../i18n/translations';
import { getLocalePath } from '../i18n/translations';
import { t } from '../i18n/ui';
import { getWhatsAppTrialLink, getWhatsAppBuyLink } from '../i18n/whatsapp';
import heroBgSrc from '../assets/images/streamvault-hero-background.png';

interface Props {
  locale: Locale;
  planId: string;
}

const { locale, planId } = Astro.props;
const currency = t(locale, 'pricing.currency');
const currencyBefore = currency === '€';

interface PlanConfig {
  nameKey: string;
  priceKey: string;
  periodKey: string;
  perMonthKey?: string;
  tierLabelKey: string;
  connections: number;
  vodKey: string;
  antiFreezeKey: string;
  supportKey: string;
  quality: string;
}

const planConfigs: Record<string, PlanConfig> = {
  '1-month': {
    nameKey: 'pricing.monthly',
    priceKey: 'pricing.monthly.price',
    periodKey: 'pricing.monthly.period',
    tierLabelKey: 'pricing.trialLabel',
    connections: 1,
    vodKey: 'pricing.feat.vod60k',
    antiFreezeKey: 'pricing.feat.antiFreezeStd',
    supportKey: 'product.supportStd',
    quality: 'basic',
  },
  '3-months': {
    nameKey: 'pricing.3months',
    priceKey: 'pricing.3months.price',
    periodKey: 'pricing.3months.period',
    perMonthKey: 'pricing.3months.perMonth',
    tierLabelKey: 'pricing.starterFavorite',
    connections: 1,
    vodKey: 'pricing.feat.vod65k',
    antiFreezeKey: 'pricing.feat.antiFreezePrem',
    supportKey: 'product.supportPremium',
    quality: 'basic',
  },
  '6-months': {
    nameKey: 'pricing.6months',
    priceKey: 'pricing.6months.price',
    periodKey: 'pricing.6months.period',
    perMonthKey: 'pricing.6months.perMonth',
    tierLabelKey: 'pricing.proLabel',
    connections: 2,
    vodKey: 'pricing.feat.vod70k',
    antiFreezeKey: 'pricing.feat.antiFreezeElite',
    supportKey: 'product.supportElite',
    quality: 'basic',
  },
  '12-months': {
    nameKey: 'pricing.12months',
    priceKey: 'pricing.12months.price',
    periodKey: 'pricing.12months.period',
    perMonthKey: 'pricing.12months.perMonth',
    tierLabelKey: 'pricing.ultimateLabel',
    connections: 3,
    vodKey: 'pricing.feat.vod80k',
    antiFreezeKey: 'pricing.feat.antiFreezeUltra',
    supportKey: 'product.supportUltra',
    quality: 'premium',
  },
};

const config = planConfigs[planId];
if (!config) return Astro.redirect(getLocalePath(locale));

const planName = t(locale, config.nameKey);
const tierLabel = t(locale, config.tierLabelKey);
const price = t(locale, config.priceKey);
const period = t(locale, config.periodKey);
const perMonth = config.perMonthKey ? t(locale, config.perMonthKey) : '';
const qualityText = config.quality === 'premium' ? t(locale, 'product.qualityPremium') : t(locale, 'product.qualityBasic');

const specs = [
  {
    label: t(locale, 'product.channels'),
    value: t(locale, 'product.channelsDesc'),
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M6 20h12M3.5 4h17A1.5 1.5 0 0122 5.5v9a1.5 1.5 0 01-1.5 1.5h-17A1.5 1.5 0 012 14.5v-9A1.5 1.5 0 013.5 4z" />`,
  },
  {
    label: t(locale, 'product.vodLibrary'),
    value: t(locale, config.vodKey),
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z" />`,
  },
  {
    label: t(locale, 'product.connections'),
    value: `${config.connections}`,
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />`,
  },
  {
    label: t(locale, 'product.quality'),
    value: qualityText,
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />`,
  },
  {
    label: t(locale, 'product.antiFreeze'),
    value: t(locale, config.antiFreezeKey),
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />`,
  },
  {
    label: t(locale, 'product.support'),
    value: t(locale, config.supportKey),
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" />`,
  },
];

const pricingUrl = getLocalePath(locale) + '#pricing';
const whatsappTrialUrl = getWhatsAppTrialLink(locale);
const whatsappBuyUrl = getWhatsAppBuyLink(locale, config.nameKey);

const devices = ['Firestick', 'Android TV', 'Apple TV', 'Smart TV', 'iPhone', 'Android', 'PC/Mac'];
---
<section class="relative min-h-screen pt-24 pb-16 overflow-hidden">
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <Image
      src={heroBgSrc}
      alt=""
      widths={[640, 1024, 1408, 1920]}
      sizes="100vw"
      format="webp"
      quality={65}
      loading="eager"
      decoding="async"
      class="absolute inset-0 w-full h-full object-cover opacity-30 contrast-[1.1] brightness-[0.8] saturate-[0.9]"
    />
  </div>
  <div class="absolute inset-0 z-0 bg-gradient-to-b from-[#030712]/80 via-[#030712]/60 to-[#030712]/90 pointer-events-none" aria-hidden="true"></div>
  <div class="absolute inset-0 z-[1] pointer-events-none" aria-hidden="true">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[120%] h-[400px] bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(59,130,246,0.06),transparent)]"></div>
    <div class="absolute top-1/3 right-0 w-80 h-80 bg-brand-500/[0.03] rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/3 left-0 w-64 h-64 bg-brand-600/[0.03] rounded-full blur-3xl"></div>
  </div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <a href={pricingUrl} class="inline-flex items-center gap-2 text-slate-400 hover:text-brand-400 transition-colors mb-8 group">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      {t(locale, 'product.backToPricing')}
    </a>

    <div class="text-center mb-12">
      <p class="text-xs font-bold uppercase tracking-widest text-brand-400 mb-2">{tierLabel}</p>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-2">
        {t(locale, 'product.heading')} <span class="text-brand-400">{t(locale, 'product.headingAccent')}</span>
      </h1>
    </div>

    <div class="bg-dark-800/60 border border-white/[0.06] rounded-2xl p-8 md:p-10 mb-8 backdrop-blur-sm">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6 mb-10 pb-8 border-b border-white/[0.06]">
        <div>
          <h2 class="text-2xl font-bold text-white mb-1">{planName}</h2>
          <p class="text-slate-400">{period}</p>
        </div>
        <div class="text-right">
          <div class="flex items-baseline gap-1 justify-end md:justify-start">
            {currencyBefore && <span class="text-lg text-slate-400">{currency}</span>}
            <span class="text-5xl font-black text-white">{price}</span>
            {!currencyBefore && <span class="text-lg text-slate-400 ml-1">{currency}</span>}
          </div>
          {perMonth && (
            <p class="text-sm text-brand-400 mt-1 font-medium">
              {currencyBefore ? `${currency}${perMonth}` : `${perMonth} ${currency}`}{t(locale, 'product.perMonth')}
            </p>
          )}
        </div>
      </div>

      <h3 class="text-lg font-semibold text-white mb-6">{t(locale, 'product.techSpecs')}</h3>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {specs.map((spec) => (
          <div class="flex items-start gap-4 p-4 rounded-xl bg-white/[0.03] border border-white/[0.04]">
            <div class="w-10 h-10 rounded-lg bg-brand-500/10 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <Fragment set:html={spec.icon} />
              </svg>
            </div>
            <div class="flex-1">
              <p class="text-sm font-medium text-slate-400">{spec.label}</p>
              <p class="text-white font-semibold">{spec.value}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="relative rounded-2xl p-8 md:p-10 mb-8 overflow-hidden border border-white/[0.08] bg-white/[0.04] backdrop-blur-xl">
      <div class="absolute inset-0 bg-gradient-to-br from-brand-500/10 via-transparent to-brand-500/5 pointer-events-none" aria-hidden="true"></div>
      <div class="relative">
        <div class="flex flex-col md:flex-row md:items-center gap-6">
          <div class="flex-1">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-full bg-green-500/20 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              </div>
              <h3 class="text-xl font-bold text-white">{t(locale, 'trial.heading')}</h3>
            </div>
            <p class="text-brand-300 font-medium mb-2">{t(locale, 'trial.subtitle')}</p>
            <p class="text-slate-400 text-sm mb-4">{t(locale, 'trial.desc')}</p>
            <div class="flex flex-wrap gap-4 text-xs text-slate-300">
              <span class="flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                {t(locale, 'trial.noCreditCard')}
              </span>
              <span class="flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                {t(locale, 'trial.instantAccess')}
              </span>
              <span class="flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                {t(locale, 'trial.fullAccess')}
              </span>
            </div>
          </div>
          <div class="flex-shrink-0">
            <a
              href={whatsappTrialUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-6 py-3.5 bg-green-600 hover:bg-green-500 text-white font-bold rounded-xl transition-all duration-200 shadow-lg shadow-green-600/30 hover:shadow-green-500/40 hover:scale-[1.02]"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              {t(locale, 'trial.requestBtn')}
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div class="rounded-2xl p-6 bg-dark-800/60 border border-white/[0.06] backdrop-blur-sm">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-3 h-3 rounded-full bg-green-500 animate-pulse"></div>
          <h4 class="text-white font-semibold">{t(locale, 'product.serverStatus')}</h4>
        </div>
        <p class="text-3xl font-black text-green-400">{t(locale, 'product.uptime')}</p>
        <div class="mt-3 flex gap-1">
          {[...Array(20)].map((_, i) => (
            <div class="flex-1 h-2 rounded-full bg-green-500/80"></div>
          ))}
        </div>
      </div>

      <div class="rounded-2xl p-6 bg-dark-800/60 border border-white/[0.06] backdrop-blur-sm">
        <h4 class="text-white font-semibold mb-4">{t(locale, 'product.compatibleDevices')}</h4>
        <div class="flex flex-wrap gap-2">
          {devices.map((device) => (
            <span class="px-3 py-1.5 rounded-lg bg-white/[0.05] border border-white/[0.08] text-slate-300 text-xs font-medium">{device}</span>
          ))}
        </div>
      </div>
    </div>

    <div class="flex flex-col sm:flex-row gap-4">
      <a
        href={whatsappBuyUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex-1 inline-flex items-center justify-center gap-2 px-8 py-4 bg-brand-500 hover:bg-brand-400 text-white text-lg font-bold rounded-xl transition-all duration-200 shadow-xl shadow-brand-500/30 hover:shadow-brand-400/50 hover:scale-[1.02]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        {t(locale, 'product.buyNow')}
      </a>
      <a
        href={pricingUrl}
        class="flex-1 inline-flex items-center justify-center gap-2 px-8 py-4 border border-white/10 text-slate-300 hover:text-white hover:bg-white/5 hover:border-white/20 rounded-xl transition-all duration-200 text-lg font-medium"
      >
        {t(locale, 'product.backToPricing')}
      </a>
    </div>
  </div>
</section>
