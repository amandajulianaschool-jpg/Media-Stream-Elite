---
const plans = [
  {
    name: 'Monthly',
    price: '12.99',
    period: '/month',
    features: [
      '20,000+ Live Channels',
      '4K Ultra HD Quality',
      'Anti-Freeze Technology 2.0',
      '2 Device Connections',
      '24/7 Support',
      'All Devices Supported',
    ],
    popular: false,
    cta: 'Get Started',
  },
  {
    name: '6 Months',
    price: '49.99',
    period: '/6 months',
    perMonth: '8.33',
    features: [
      'Everything in Monthly',
      'Priority Support',
      'EPG TV Guide',
      '2 Device Connections',
      'VOD Library Access',
      'Save 36%',
    ],
    popular: false,
    cta: 'Choose Plan',
  },
  {
    name: '12 Months',
    price: '79.99',
    period: '/year',
    perMonth: '6.67',
    features: [
      'Everything in 6 Months',
      'VIP Priority Support',
      'Premium EPG Guide',
      '2 Device Connections',
      'Full VOD + Series',
      'Save 49% — Best Value',
    ],
    popular: true,
    cta: 'Best Value — Join Now',
  },
];
---
<section id="pricing" class="relative py-24 md:py-32" aria-labelledby="pricing-heading">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-dark-800/30 to-transparent pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1 rounded-full bg-brand-500/10 border border-brand-500/20 text-brand-400 text-sm font-medium mb-4">Simple Pricing</span>
      <h2 id="pricing-heading" class="text-3xl md:text-4xl lg:text-5xl font-bold text-white">
        Choose Your <span class="text-brand-400">Streaming Plan</span>
      </h2>
      <p class="mt-4 text-lg text-slate-400 max-w-2xl mx-auto">No hidden fees. No contracts. Cancel anytime. All plans include a 24-hour free trial.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 max-w-5xl mx-auto">
      {plans.map((plan) => (
        <div class={`relative rounded-2xl p-8 transition-all duration-300 hover:-translate-y-2 ${
          plan.popular
            ? 'bg-gradient-to-b from-brand-500/20 to-dark-800/80 border-2 border-brand-500/50 shadow-2xl shadow-brand-500/20'
            : 'bg-dark-800/40 border border-white/[0.06] hover:border-brand-500/20 hover:shadow-xl hover:shadow-brand-500/5'
        }`}>
          {plan.popular && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2">
              <span class="px-4 py-1.5 rounded-full bg-brand-500 text-white text-sm font-bold shadow-lg shadow-brand-500/40">
                Most Popular
              </span>
            </div>
          )}

          <div class="text-center mb-8">
            <h3 class="text-lg font-semibold text-slate-300 mb-4">{plan.name}</h3>
            <div class="flex items-baseline justify-center gap-1">
              <span class="text-sm text-slate-400">€</span>
              <span class={`text-5xl font-black ${plan.popular ? 'text-white' : 'text-white'}`}>{plan.price}</span>
            </div>
            <p class="text-sm text-slate-500 mt-1">{plan.period}</p>
            {plan.perMonth && (
              <p class="text-sm text-brand-400 mt-2 font-medium">€{plan.perMonth}/month</p>
            )}
          </div>

          <ul class="space-y-3 mb-8" role="list">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-3 text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class={`w-5 h-5 flex-shrink-0 mt-0.5 ${plan.popular ? 'text-brand-400' : 'text-brand-500/70'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-slate-300">{feature}</span>
              </li>
            ))}
          </ul>

          <a
            href="#"
            class={`block w-full text-center py-3.5 rounded-xl font-semibold transition-all duration-200 ${
              plan.popular
                ? 'bg-brand-500 hover:bg-brand-400 text-white shadow-lg shadow-brand-500/30 hover:shadow-brand-400/40 hover:scale-[1.02]'
                : 'bg-white/5 hover:bg-white/10 text-white border border-white/10 hover:border-white/20'
            }`}
            aria-label={`Select ${plan.name} plan for €${plan.price}`}
          >
            {plan.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
