---
import type { Locale } from '../i18n/translations';
import { getRelativeLocaleUrl } from '../i18n/translations';
import { t } from '../i18n/ui';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const currency = t(locale, 'pricing.currency');
const currencyBefore = currency === '€';

const plans = [
  {
    id: '1-month',
    name: t(locale, 'pricing.monthly'),
    tierLabel: t(locale, 'pricing.trialLabel'),
    price: t(locale, 'pricing.monthly.price'),
    period: t(locale, 'pricing.monthly.period'),
    perMonth: '',
    features: [
      t(locale, 'pricing.feat.channels'),
      t(locale, 'pricing.feat.vod60k'),
      t(locale, 'pricing.feat.antiFreezeStd'),
      t(locale, 'pricing.feat.support'),
      t(locale, 'pricing.feat.allDevices'),
    ],
    popular: false,
    badge: '',
    highlight: false,
  },
  {
    id: '3-months',
    name: t(locale, 'pricing.3months'),
    tierLabel: t(locale, 'pricing.starterFavorite'),
    price: t(locale, 'pricing.3months.price'),
    period: t(locale, 'pricing.3months.period'),
    perMonth: t(locale, 'pricing.3months.perMonth'),
    features: [
      t(locale, 'pricing.feat.channels'),
      t(locale, 'pricing.feat.vod65k'),
      t(locale, 'pricing.feat.antiFreezePrem'),
      t(locale, 'pricing.feat.support'),
      t(locale, 'pricing.feat.save30'),
    ],
    popular: false,
    badge: t(locale, 'pricing.starterFavorite'),
    highlight: false,
  },
  {
    id: '6-months',
    name: t(locale, 'pricing.6months'),
    tierLabel: t(locale, 'pricing.proLabel'),
    price: t(locale, 'pricing.6months.price'),
    period: t(locale, 'pricing.6months.period'),
    perMonth: t(locale, 'pricing.6months.perMonth'),
    features: [
      t(locale, 'pricing.feat.channels'),
      t(locale, 'pricing.feat.vod70k'),
      t(locale, 'pricing.feat.antiFreezeElite'),
      t(locale, 'pricing.feat.support'),
      t(locale, 'pricing.feat.save42'),
    ],
    popular: false,
    badge: t(locale, 'pricing.proLabel'),
    highlight: false,
  },
  {
    id: '12-months',
    name: t(locale, 'pricing.12months'),
    tierLabel: t(locale, 'pricing.ultimateLabel'),
    price: t(locale, 'pricing.12months.price'),
    period: t(locale, 'pricing.12months.period'),
    perMonth: t(locale, 'pricing.12months.perMonth'),
    features: [
      t(locale, 'pricing.feat.channels'),
      t(locale, 'pricing.feat.vod80k'),
      t(locale, 'pricing.feat.antiFreezeUltra'),
      t(locale, 'pricing.feat.support'),
      t(locale, 'pricing.feat.save55'),
    ],
    popular: true,
    badge: t(locale, 'pricing.bestValue'),
    highlight: true,
  },
];
---
<section id="pricing" class="relative py-24 md:py-32" aria-labelledby="pricing-heading">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-dark-800/30 to-transparent pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1 rounded-full bg-brand-500/10 border border-brand-500/20 text-brand-400 text-sm font-medium mb-4">{t(locale, 'pricing.badge')}</span>
      <h2 id="pricing-heading" class="text-3xl md:text-4xl lg:text-5xl font-bold text-white">
        {t(locale, 'pricing.heading')} <span class="text-brand-400">{t(locale, 'pricing.headingAccent')}</span>
      </h2>
      <p class="mt-4 text-lg text-slate-400 max-w-2xl mx-auto">{t(locale, 'pricing.subtitle')}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 lg:gap-6 max-w-7xl mx-auto">
      {plans.map((plan) => (
        <div class={`relative rounded-2xl p-6 lg:p-7 transition-all duration-300 hover:-translate-y-2 ${
          plan.highlight
            ? 'bg-gradient-to-b from-brand-500/20 to-dark-800/80 border-2 border-brand-500/50 shadow-2xl shadow-brand-500/20 ring-1 ring-brand-500/30'
            : 'bg-dark-800/40 border border-white/[0.06] hover:border-brand-500/20 hover:shadow-xl hover:shadow-brand-500/5'
        }`}>
          {plan.highlight && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2">
              <span class="px-4 py-1.5 rounded-full bg-brand-500 text-white text-sm font-bold shadow-lg shadow-brand-500/40 animate-pulse-glow whitespace-nowrap">
                {plan.badge}
              </span>
            </div>
          )}
          {plan.badge && !plan.highlight && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2">
              <span class="px-4 py-1.5 rounded-full bg-dark-800/90 border border-brand-500/30 text-brand-400 text-sm font-bold shadow-lg whitespace-nowrap">
                {plan.badge}
              </span>
            </div>
          )}

          <div class="text-center mb-6">
            <p class="text-xs font-bold uppercase tracking-widest text-brand-400 mb-1">{plan.tierLabel}</p>
            <h3 class="text-base font-semibold text-slate-300 mb-3">{plan.name}</h3>
            <div class="flex items-baseline justify-center gap-1">
              {currencyBefore && <span class="text-sm text-slate-400">{currency}</span>}
              <span class="text-4xl lg:text-5xl font-black text-white">{plan.price}</span>
              {!currencyBefore && <span class="text-sm text-slate-400 ml-1">{currency}</span>}
            </div>
            <p class="text-sm text-slate-500 mt-1">{plan.period}</p>
            {plan.perMonth && (
              <p class="text-sm text-brand-400 mt-2 font-medium">
                {currencyBefore ? `${currency}${plan.perMonth}` : `${plan.perMonth} ${currency}`}{t(locale, 'pricing.perMonth')}
              </p>
            )}
          </div>

          <ul class="space-y-2.5 mb-6" role="list">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-2.5 text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class={`w-4 h-4 flex-shrink-0 mt-0.5 ${plan.highlight ? 'text-brand-400' : 'text-brand-500/70'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-slate-300">{feature}</span>
              </li>
            ))}
          </ul>

          <a
            href={getRelativeLocaleUrl(locale, `product/${plan.id}/`)}
            class={`block w-full text-center py-3 rounded-xl font-semibold transition-all duration-200 ${
              plan.highlight
                ? 'bg-brand-500 hover:bg-brand-400 text-white shadow-lg shadow-brand-500/30 hover:shadow-brand-400/40 hover:scale-[1.02]'
                : 'bg-white/5 hover:bg-white/10 text-white border border-white/10 hover:border-white/20'
            }`}
          >
            {t(locale, 'pricing.choosePlan')}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
