---
import FaqAccordion from './react/FaqAccordion';
import type { Locale } from '../i18n/translations';
import { t } from '../i18n/ui';

interface Props {
  locale?: Locale;
  headingLevel?: 'h1' | 'h2';
}

const { locale = 'en', headingLevel = 'h2' } = Astro.props;
const HeadingTag = headingLevel;

const faqs = [
  { question: t(locale, 'faq.q1'), answer: t(locale, 'faq.a1') },
  { question: t(locale, 'faq.q2'), answer: t(locale, 'faq.a2') },
  { question: t(locale, 'faq.q3'), answer: t(locale, 'faq.a3') },
  { question: t(locale, 'faq.q4'), answer: t(locale, 'faq.a4') },
  { question: t(locale, 'faq.q5'), answer: t(locale, 'faq.a5') },
  { question: t(locale, 'faq.q6'), answer: t(locale, 'faq.a6') },
  { question: t(locale, 'faq.q7'), answer: t(locale, 'faq.a7') },
  { question: t(locale, 'faq.q8'), answer: t(locale, 'faq.a8') },
  { question: t(locale, 'faq.q9'), answer: t(locale, 'faq.a9') },
  { question: t(locale, 'faq.q10'), answer: t(locale, 'faq.a10') },
  { question: t(locale, 'faq.q11'), answer: t(locale, 'faq.a11') },
];
---
<section id="faq" class="relative py-24 md:py-32" aria-labelledby="faq-heading">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-dark-800/30 to-transparent pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1 rounded-full bg-brand-500/10 border border-brand-500/20 text-brand-400 text-sm font-medium mb-4">{t(locale, 'faq.badge')}</span>
      <HeadingTag id="faq-heading" class="text-3xl md:text-4xl lg:text-5xl font-bold text-white">
        {t(locale, 'faq.heading')} <span class="text-brand-400">{t(locale, 'faq.headingAccent')}</span>
      </HeadingTag>
      <p class="mt-4 text-lg text-slate-400 max-w-2xl mx-auto">{t(locale, 'faq.subtitle')}</p>
    </div>

    <FaqAccordion client:load faqs={faqs} />
  </div>
</section>
