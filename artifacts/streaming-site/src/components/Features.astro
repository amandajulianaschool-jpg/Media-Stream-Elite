---
const features = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`,
    title: 'Anti-Freeze Technology 2.0',
    description: 'Our proprietary buffering elimination system uses intelligent pre-loading and adaptive bitrate streaming. Enjoy crystal-clear playback even on 10 Mbps connections.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    title: 'Global Content Library',
    description: 'Stream 20,000+ channels from every continent. Live sports, international news, premium movies, and trending series from 150+ countries — all in one place.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" /></svg>`,
    title: '24/7 Expert Support',
    description: 'Our dedicated team is available around the clock via WhatsApp and live chat. Average response time under 2 minutes. Installation help, troubleshooting, and account management.',
  },
];
---
<section id="features" class="relative py-24 md:py-32" aria-labelledby="features-heading">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-dark-800/50 to-transparent pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1 rounded-full bg-brand-500/10 border border-brand-500/20 text-brand-400 text-sm font-medium mb-4">Why StreamVault</span>
      <h2 id="features-heading" class="text-3xl md:text-4xl lg:text-5xl font-bold text-white">
        Premium Features, <span class="text-brand-400">Zero Compromise</span>
      </h2>
      <p class="mt-4 text-lg text-slate-400 max-w-2xl mx-auto">Everything you need for the ultimate streaming experience, built with cutting-edge technology.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {features.map((feature) => (
        <article class="group relative rounded-2xl bg-dark-800/40 border border-white/[0.06] p-8 transition-all duration-300 hover:-translate-y-2 hover:border-brand-500/30 hover:shadow-2xl hover:shadow-brand-500/10">
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-b from-brand-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none" aria-hidden="true"></div>
          <div class="relative">
            <div class="w-14 h-14 rounded-xl bg-brand-500/10 border border-brand-500/20 flex items-center justify-center text-brand-400 mb-6 group-hover:bg-brand-500/20 group-hover:scale-110 transition-all duration-300">
              <Fragment set:html={feature.icon} />
            </div>
            <h3 class="text-xl font-bold text-white mb-3">{feature.title}</h3>
            <p class="text-slate-400 leading-relaxed">{feature.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
