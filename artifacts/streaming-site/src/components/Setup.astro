---
import type { Locale } from '../i18n/translations';
import { t } from '../i18n/ui';

interface Props {
  locale?: Locale;
  headingLevel?: 'h1' | 'h2';
}

const { locale = 'en', headingLevel = 'h2' } = Astro.props;
const HeadingTag = headingLevel;

const steps = [
  {
    number: '01',
    title: t(locale, 'setup.step1.title'),
    description: t(locale, 'setup.step1.desc'),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>`,
  },
  {
    number: '02',
    title: t(locale, 'setup.step2.title'),
    description: t(locale, 'setup.step2.desc'),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`,
  },
  {
    number: '03',
    title: t(locale, 'setup.step3.title'),
    description: t(locale, 'setup.step3.desc'),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" /><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
  },
];
---
<section id="setup" class="relative py-24 md:py-32" aria-labelledby="setup-heading">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-brand-500/[0.03] to-transparent pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1 rounded-full bg-brand-500/10 border border-brand-500/20 text-brand-400 text-sm font-medium mb-4">{t(locale, 'setup.badge')}</span>
      <HeadingTag id="setup-heading" class="text-3xl md:text-4xl lg:text-5xl font-bold text-white">
        {t(locale, 'setup.heading')} <span class="text-brand-400">{t(locale, 'setup.headingAccent')}</span>
      </HeadingTag>
      <p class="mt-4 text-lg text-slate-400 max-w-2xl mx-auto">{t(locale, 'setup.subtitle')}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12 max-w-5xl mx-auto">
      {steps.map((step, index) => (
        <div class="relative text-center group">
          {index < steps.length - 1 && (
            <div class="hidden md:block absolute top-16 left-[60%] w-[80%] h-px bg-gradient-to-r from-brand-500/30 to-transparent" aria-hidden="true"></div>
          )}

          <div class="relative inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-gradient-to-br from-brand-500/20 to-brand-600/10 border border-brand-500/20 mb-6 group-hover:scale-110 group-hover:border-brand-500/40 transition-all duration-300 shadow-lg shadow-brand-500/10">
            <div class="text-brand-400">
              <Fragment set:html={step.icon} />
            </div>
            <span class="absolute -top-2 -right-2 w-7 h-7 rounded-full bg-brand-500 text-white text-xs font-bold flex items-center justify-center shadow-lg shadow-brand-500/40">{step.number}</span>
          </div>

          <h3 class="text-xl font-bold text-white mb-3">{step.title}</h3>
          <p class="text-slate-400 leading-relaxed max-w-xs mx-auto">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
