---
import { Image } from 'astro:assets';
import type { Locale } from '../i18n/translations';
import { t } from '../i18n/ui';

import premierLeagueSrc from '../assets/images/content/streamvault-premier-league.png';
import championsLeagueSrc from '../assets/images/content/streamvault-champions-league.png';
import nbaSrc from '../assets/images/content/streamvault-nba-basketball.png';
import formula1Src from '../assets/images/content/streamvault-formula1-racing.png';
import ufcBoxingSrc from '../assets/images/content/streamvault-ufc-boxing.png';
import cricketSrc from '../assets/images/content/streamvault-cricket.png';
import actionSrc from '../assets/images/content/streamvault-action-movies.png';
import scifiSrc from '../assets/images/content/streamvault-scifi-movies.png';
import dramaThrillerSrc from '../assets/images/content/streamvault-drama-thriller.png';
import comedySrc from '../assets/images/content/streamvault-comedy-movies.png';
import horrorSrc from '../assets/images/content/streamvault-horror-movies.png';
import familySrc from '../assets/images/content/streamvault-family-movies.png';
import crimeMysterySrc from '../assets/images/content/streamvault-crime-mystery.png';
import kdramaSrc from '../assets/images/content/streamvault-kdrama-series.png';
import documentarySrc from '../assets/images/content/streamvault-documentary.png';
import animeSrc from '../assets/images/content/streamvault-anime-series.png';
import realityTVSrc from '../assets/images/content/streamvault-reality-tv.png';
import classicsSrc from '../assets/images/content/streamvault-classic-movies.png';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;

const liveSportsTitle = t(locale, 'content.liveSports');

const categories = [
  {
    title: liveSportsTitle,
    isLive: true,
    items: [
      { name: t(locale, 'content.premierLeague'), image: premierLeagueSrc, altKey: 'alt.premierLeague' },
      { name: t(locale, 'content.championsLeague'), image: championsLeagueSrc, altKey: 'alt.championsLeague' },
      { name: t(locale, 'content.nba'), image: nbaSrc, altKey: 'alt.nba' },
      { name: t(locale, 'content.formula1'), image: formula1Src, altKey: 'alt.formula1' },
      { name: t(locale, 'content.ufcBoxing'), image: ufcBoxingSrc, altKey: 'alt.ufcBoxing' },
      { name: t(locale, 'content.cricket'), image: cricketSrc, altKey: 'alt.cricket' },
    ],
  },
  {
    title: t(locale, 'content.latestMovies'),
    isLive: false,
    items: [
      { name: t(locale, 'content.action'), image: actionSrc, altKey: 'alt.action' },
      { name: t(locale, 'content.scifi'), image: scifiSrc, altKey: 'alt.scifi' },
      { name: t(locale, 'content.dramaThriller'), image: dramaThrillerSrc, altKey: 'alt.dramaThriller' },
      { name: t(locale, 'content.comedy'), image: comedySrc, altKey: 'alt.comedy' },
      { name: t(locale, 'content.horror'), image: horrorSrc, altKey: 'alt.horror' },
      { name: t(locale, 'content.family'), image: familySrc, altKey: 'alt.family' },
    ],
  },
  {
    title: t(locale, 'content.trendingSeries'),
    isLive: false,
    items: [
      { name: t(locale, 'content.crimeMystery'), image: crimeMysterySrc, altKey: 'alt.crimeMystery' },
      { name: t(locale, 'content.kdrama'), image: kdramaSrc, altKey: 'alt.kdrama' },
      { name: t(locale, 'content.documentary'), image: documentarySrc, altKey: 'alt.documentary' },
      { name: t(locale, 'content.anime'), image: animeSrc, altKey: 'alt.anime' },
      { name: t(locale, 'content.realityTV'), image: realityTVSrc, altKey: 'alt.realityTV' },
      { name: t(locale, 'content.classics'), image: classicsSrc, altKey: 'alt.classics' },
    ],
  },
];
---
<section id="content" class="py-24 md:py-32" aria-labelledby="content-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-12">
    <div class="text-center">
      <span class="inline-block px-4 py-1 rounded-full bg-brand-500/10 border border-brand-500/20 text-brand-400 text-sm font-medium mb-4">{t(locale, 'content.badge')}</span>
      <h2 id="content-heading" class="text-3xl md:text-4xl lg:text-5xl font-bold text-white">
        {t(locale, 'content.heading')} <span class="text-brand-400">{t(locale, 'content.headingAccent')}</span>
      </h2>
    </div>
  </div>

  {categories.map((category) => (
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-14">
      <h3 class="text-xl md:text-2xl font-bold text-white flex items-center gap-3 mb-6">
        {category.isLive && (
          <span class="w-2.5 h-2.5 rounded-full bg-red-500 animate-pulse" aria-hidden="true"></span>
        )}
        {category.title}
      </h3>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4 md:gap-5">
        {category.items.map((item) => (
          <div class="group cursor-pointer">
            <div class="relative aspect-[2/3] rounded-xl overflow-hidden transition-all duration-300 group-hover:scale-[1.04] group-hover:shadow-2xl group-hover:shadow-brand-500/10 ring-1 ring-white/[0.06] group-hover:ring-brand-500/30">
              <Image
                src={item.image}
                alt={t(locale, item.altKey)}
                widths={[200, 300, 400]}
                sizes="(max-width: 640px) 50vw, (max-width: 768px) 33vw, (max-width: 1024px) 25vw, 16vw"
                format="webp"
                quality={75}
                loading="lazy"
                decoding="async"
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/10 to-transparent"></div>
              <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                <div class="w-12 h-12 rounded-full bg-white/15 backdrop-blur-md flex items-center justify-center border border-white/20 shadow-lg">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white ml-0.5" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                </div>
              </div>
              <div class="absolute bottom-0 left-0 right-0 p-3.5">
                <p class="text-sm font-semibold text-white leading-snug drop-shadow-lg">{item.name}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  ))}
</section>
