---
import type { Locale } from '../i18n/translations';
import { t } from '../i18n/ui';
import { getWhatsAppTrialLink } from '../i18n/whatsapp';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const whatsappUrl = getWhatsAppTrialLink(locale);
---
<section id="free-trial" class="relative py-20 md:py-28" aria-labelledby="trial-heading">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-brand-500/[0.03] to-transparent pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="relative rounded-2xl p-8 md:p-12 overflow-hidden border border-white/[0.08] bg-white/[0.04] backdrop-blur-xl">
      <div class="absolute inset-0 bg-gradient-to-br from-brand-500/10 via-transparent to-green-500/5 pointer-events-none" aria-hidden="true"></div>
      <div class="absolute -top-24 -right-24 w-48 h-48 bg-brand-500/10 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>
      <div class="absolute -bottom-24 -left-24 w-48 h-48 bg-green-500/10 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>

      <div class="relative text-center">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-green-500/10 border border-green-500/20 text-green-400 text-sm font-medium mb-6">
          <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
          {t(locale, 'trial.heading')}
        </div>

        <h2 id="trial-heading" class="text-3xl md:text-4xl font-bold text-white mb-3">
          {t(locale, 'trial.heading')}
        </h2>
        <p class="text-lg text-brand-300 font-medium mb-3">{t(locale, 'trial.subtitle')}</p>
        <p class="text-slate-400 max-w-2xl mx-auto mb-8">{t(locale, 'trial.desc')}</p>

        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 px-8 py-4 bg-green-600 hover:bg-green-500 text-white text-lg font-bold rounded-xl transition-all duration-200 shadow-xl shadow-green-600/30 hover:shadow-green-500/40 hover:scale-[1.02] mb-8"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          {t(locale, 'trial.requestBtn')}
        </a>

        <div class="flex flex-wrap justify-center gap-6 text-sm text-slate-300">
          <span class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            {t(locale, 'trial.noCreditCard')}
          </span>
          <span class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            {t(locale, 'trial.instantAccess')}
          </span>
          <span class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            {t(locale, 'trial.fullAccess')}
          </span>
        </div>
      </div>
    </div>
  </div>
</section>
